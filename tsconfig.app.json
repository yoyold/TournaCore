{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "useDefineForClassFields": true,

    /* Bundler mode: Vite handles transpilation */
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    /* Deliberately stricter than `strict` alone */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,

    /* Path aliases mirror the architectural layers */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@app/*": ["src/app/*"],
      "@domain/*": ["src/domain/*"],
      "@models/*": ["src/models/*"],
      "@store/*": ["src/store/*"],
      "@services/*": ["src/services/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@pages/*": ["src/pages/*"],
      "@hooks/*": ["src/hooks/*"],
      "@utils/*": ["src/utils/*"]
    },

    /*
     * Deliberately does NOT list "@testing-library/jest-dom": that package entry
     * points at the Jest flavour of the types and then demands @types/jest. The
     * Vitest matchers are registered through the "/vitest" import in
     * src/test/setup.ts instead.
     */
    "types": ["vitest/globals"]
  },
  "include": ["src"]
}
